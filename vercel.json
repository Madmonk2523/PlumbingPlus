{
  "version": 2,
  "builds": [
    {
      "src": "api/lead.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "logo.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "Nice plumbing text.jpg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/lead",
      "dest": "/api/lead.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
